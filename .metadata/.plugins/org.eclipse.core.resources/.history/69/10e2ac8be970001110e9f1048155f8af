<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Gestión de Cajas</title>
</head>
<body>
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-cash-register text-warning"></i> Gestión de Cajas</h2>
        </div>

        <!-- Tabla de Cajas -->
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="tablaCajas">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Ubicación</th>
                                <th>Saldo Inicial</th>
                                <th>Saldo Actual</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="cuerpoTablaCajas">
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    <i class="fas fa-spinner fa-spin"></i> Cargando cajas...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Editar Caja -->
    <div class="modal fade" id="modalCaja" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title"><i class="fas fa-edit"></i> Editar Caja</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formCaja">
                        <input type="hidden" id="cajaId">
                        <div class="mb-3">
                            <label class="form-label">Nombre</label>
                            <input type="text" class="form-control" id="nombreCaja" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Ubicación</label>
                            <input type="text" class="form-control" id="ubicacionCaja">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Saldo Inicial</label>
                            <input type="number" step="0.01" class="form-control" id="saldoInicialCaja" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Saldo Actual</label>
                            <input type="number" step="0.01" class="form-control" id="saldoActualCaja" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Estado</label>
                            <select class="form-control" id="estadoCaja">
                                <option value="ACTIVA">Activa</option>
                                <option value="CERRADA">Cerrada</option>
                                <option value="MANTENIMIENTO">Mantenimiento</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-warning" onclick="guardarCaja()">
                        <i class="fas fa-save"></i> Actualizar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const API_CAJAS = '/supervisor/cajas';
        let modalCaja = null;

        document.addEventListener('DOMContentLoaded', function() {
            modalCaja = new bootstrap.Modal(document.getElementById('modalCaja'));
            cargarCajas();
        });

        function cargarCajas() {
            fetch(API_CAJAS)
                .then(res => res.json())
                .then(cajas => {
                    const tbody = document.getElementById('cuerpoTablaCajas');
                    if (!cajas || cajas.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="7" class="text-center text-muted">No hay cajas registradas</td></tr>`;
                        return;
                    }
                    let html = '';
                    cajas.forEach(c => {
                        const badge = c.estado === 'ACTIVA' ? 'success' : c.estado === 'CERRADA' ? 'danger' : 'warning';
                        html += `
                            <tr>
                                <td>${c.idCaja}</td>
                                <td><strong>${c.nombre}</strong></td>
                                <td>${c.ubicacion || '-'}</td>
                                <td>S/ ${c.saldoInicial?.toFixed(2) || '0.00'}</td>
                                <td>S/ ${c.saldoActual?.toFixed(2) || '0.00'}</td>
                                <td><span class="badge bg-${badge}">${c.estado || 'DESCONOCIDO'}</span></td>
                                <td>
                                    <button class="btn btn-sm btn-warning" onclick="editarCaja(${c.idCaja})">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                </td>
                            </tr>
                        `;
                    });
                    tbody.innerHTML = html;
                })
                .catch(err => {
                    console.error('Error:', err);
                    document.getElementById('cuerpoTablaCajas').innerHTML = 
                        `<tr><td colspan="7" class="text-center text-danger">Error al cargar las cajas</td></tr>`;
                });
        }

        function editarCaja(id) {
            fetch(`${API_CAJAS}/${id}`)
                .then(res => res.json())
                .then(c => {
                    document.getElementById('cajaId').value = c.idCaja;
                    document.getElementById('nombreCaja').value = c.nombre || '';
                    document.getElementById('ubicacionCaja').value = c.ubicacion || '';
                    document.getElementById('saldoInicialCaja').value = c.saldoInicial || 0;
                    document.getElementById('saldoActualCaja').value = c.saldoActual || 0;
                    document.getElementById('estadoCaja').value = c.estado || 'ACTIVA';
                    modalCaja.show();
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Error al cargar la caja');
                });
        }

        function guardarCaja() {
            const id = document.getElementById('cajaId').value;
            const caja = {
                nombre: document.getElementById('nombreCaja').value.trim(),
                ubicacion: document.getElementById('ubicacionCaja').value.trim(),
                saldoInicial: parseFloat(document.getElementById('saldoInicialCaja').value) || 0,
                saldoActual: parseFloat(document.getElementById('saldoActualCaja').value) || 0,
                estado: document.getElementById('estadoCaja').value
            };

            if (!caja.nombre) {
                alert('El nombre es obligatorio');
                return;
            }

            fetch(`${API_CAJAS}/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(caja)
            })
            .then(res => {
                if (!res.ok) throw new Error('Error al actualizar');
                return res.json();
            })
            .then(() => {
                modalCaja.hide();
                cargarCajas();
                alert('Caja actualizada exitosamente');
            })
            .catch(err => {
                console.error('Error:', err);
                alert('Error al actualizar la caja');
            });
        }
    </script>
</body>
</html>