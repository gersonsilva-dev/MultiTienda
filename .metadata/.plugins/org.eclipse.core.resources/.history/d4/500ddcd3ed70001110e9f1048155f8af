package com.techventa.multitienda.admin.service;

import com.techventa.multitienda.admin.model.Incidencia;
import com.techventa.multitienda.admin.repository.IncidenciaRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.util.List;
import java.util.Optional;

@Service
public class IncidenciaService {

    @Autowired
    private IncidenciaRepository incidenciaRepository;

    // ========================================================
    // LISTAR TODAS CON USUARIO
    // ========================================================
    public List<Incidencia> listarTodas() {
        return incidenciaRepository.findAllWithUser();
    }

    // ========================================================
    // BUSCAR POR ID CON USUARIO
    // ========================================================
    public Optional<Incidencia> buscarPorId(Integer id) {
        return incidenciaRepository.findByIdWithUser(id);
    }

    // ========================================================
    // LISTAR POR ESTADO CON USUARIO
    // ========================================================
    public List<Incidencia> listarPorEstado(Integer idEstado) {
        return incidenciaRepository.findByEstadoWithUser(idEstado);
    }

    // ========================================================
    // RESOLVER INCIDENCIA
    // ========================================================
    public Incidencia resolver(Integer id, Integer idAdmin, String respuesta) {
        Optional<Incidencia> opt = incidenciaRepository.findById(id);
        if (opt.isEmpty()) return null;
        
        Incidencia incidencia = opt.get();
        incidencia.setIdAdminResuelve(idAdmin);
        incidencia.setRespuestaAdmin(respuesta);
        incidencia.setFechaResolucion(java.time.LocalDateTime.now());
        incidencia.setIdEstadoIncidencia(3); // RESUELTO
        
        return incidenciaRepository.save(incidencia);
    }

    // ========================================================
    // CERRAR INCIDENCIA
    // ========================================================
    public Incidencia cerrar(Integer id) {
        Optional<Incidencia> opt = incidenciaRepository.findById(id);
        if (opt.isEmpty()) return null;
        
        Incidencia incidencia = opt.get();
        incidencia.setIdEstadoIncidencia(4); // CERRADO
        incidencia.setFechaCierre(java.time.LocalDateTime.now());
        
        return incidenciaRepository.save(incidencia);
    }
}