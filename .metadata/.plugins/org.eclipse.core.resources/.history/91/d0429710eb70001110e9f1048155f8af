<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Gestión de Cajas</title>
</head>
<body>
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-cash-register text-warning"></i> Gestión de Cajas</h2>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="tablaCajas">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Número</th>
                                <th>Tienda</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="cuerpoTablaCajas">
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-spinner fa-spin"></i> Cargando cajas...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL CON CSS PURO (SIN BOOTSTRAP) -->
    <div id="modalCaja" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; justify-content:center; align-items:center;">
        <div style="background:white; border-radius:8px; max-width:500px; width:90%; padding:0; box-shadow:0 4px 20px rgba(0,0,0,0.3);">
            <div style="background:#D97706; color:white; padding:15px 20px; border-radius:8px 8px 0 0; display:flex; justify-content:space-between; align-items:center;">
                <h5 style="margin:0;"><i class="fas fa-edit"></i> Editar Caja</h5>
                <button onclick="cerrarModalCaja()" style="background:none; border:none; color:white; font-size:1.5rem; cursor:pointer;">&times;</button>
            </div>
            <div style="padding:20px;">
                <form id="formCaja">
                    <input type="hidden" id="cajaId">
                    <div style="margin-bottom:15px;">
                        <label style="display:block; font-weight:600; margin-bottom:5px;">Nombre</label>
                        <input type="text" class="form-control" id="nombreCaja" required style="width:100%; padding:8px 12px; border:1px solid #ddd; border-radius:4px;">
                    </div>
                    <div style="margin-bottom:15px;">
                        <label style="display:block; font-weight:600; margin-bottom:5px;">Número de Caja</label>
                        <input type="number" class="form-control" id="numeroCaja" required style="width:100%; padding:8px 12px; border:1px solid #ddd; border-radius:4px;">
                    </div>
                    <div style="margin-bottom:15px;">
                        <label style="display:block; font-weight:600; margin-bottom:5px;">Estado</label>
                        <select class="form-control" id="estadoCaja" style="width:100%; padding:8px 12px; border:1px solid #ddd; border-radius:4px;">
                            <option value="1">Abierta</option>
                            <option value="2">Cerrada</option>
                            <option value="3">Mantenimiento</option>
                        </select>
                    </div>
                </form>
            </div>
            <div style="padding:15px 20px; border-top:1px solid #eee; display:flex; justify-content:flex-end; gap:10px;">
                <button onclick="cerrarModalCaja()" style="padding:8px 20px; background:#6c757d; color:white; border:none; border-radius:4px; cursor:pointer;">Cancelar</button>
                <button onclick="guardarCaja()" style="padding:8px 20px; background:#D97706; color:white; border:none; border-radius:4px; cursor:pointer;">
                    <i class="fas fa-save"></i> Actualizar
                </button>
            </div>
        </div>
    </div>

    <script>
        (function() {
            const API_CAJAS = '/supervisor/cajas';

            // ========================================================
            // FUNCIONES DEL MODAL (SIN BOOTSTRAP)
            // ========================================================
            function abrirModalCaja() {
                const modal = document.getElementById('modalCaja');
                modal.style.display = 'flex';
                document.body.style.overflow = 'hidden'; // Evita scroll
            }

            function cerrarModalCaja() {
                const modal = document.getElementById('modalCaja');
                modal.style.display = 'none';
                document.body.style.overflow = '';
            }

            // ========================================================
            // CARGAR CAJAS
            // ========================================================
            function cargarCajas() {
                console.log('🔍 Cargando cajas...');
                
                fetch(API_CAJAS)
                    .then(res => {
                        if (!res.ok) throw new Error(`HTTP ${res.status}`);
                        return res.json();
                    })
                    .then(cajas => {
                        console.log('📦 Datos recibidos:', cajas);
                        
                        const tbody = document.getElementById('cuerpoTablaCajas');
                        if (!cajas || cajas.length === 0) {
                            tbody.innerHTML = `<tr><td colspan="6" class="text-center text-muted">No hay cajas registradas</td></tr>`;
                            return;
                        }
                        
                        let html = '';
                        cajas.forEach(c => {
                            const estadoNombre = c.estadoCaja?.nombreEstado || 'DESCONOCIDO';
                            const badge = estadoNombre === 'ABIERTA' ? 'success' : 
                                         estadoNombre === 'CERRADA' ? 'danger' : 'warning';
                            
                            html += `
                                <tr>
                                    <td>${c.idCaja}</td>
                                    <td><strong>${c.nombreCaja || 'Sin nombre'}</strong></td>
                                    <td>${c.numeroCaja || '-'}</td>
                                    <td>${c.tienda?.nombreTienda || 'N/A'}</td>
                                    <td><span class="badge bg-${badge}">${estadoNombre}</span></td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" onclick="editarCaja(${c.idCaja})">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>
                                    </td>
                                </tr>
                            `;
                        });
                        tbody.innerHTML = html;
                        console.log('✅ Tabla renderizada correctamente');
                    })
                    .catch(err => {
                        console.error('❌ ERROR:', err);
                        document.getElementById('cuerpoTablaCajas').innerHTML = 
                            `<tr><td colspan="6" class="text-center text-danger">Error al cargar las cajas: ${err.message}</td></tr>`;
                    });
            }

            // ========================================================
            // EDITAR CAJA - SOLO AQUÍ SE ABRE EL MODAL
            // ========================================================
            function editarCaja(id) {
                console.log('✏️ Editando caja ID:', id);
                
                fetch(`${API_CAJAS}/${id}`)
                    .then(res => {
                        if (!res.ok) throw new Error('Error al obtener la caja');
                        return res.json();
                    })
                    .then(c => {
                        console.log('📝 Datos de la caja:', c);
                        
                        // Llenar el formulario
                        document.getElementById('cajaId').value = c.idCaja;
                        document.getElementById('nombreCaja').value = c.nombreCaja || '';
                        document.getElementById('numeroCaja').value = c.numeroCaja || 0;
                        document.getElementById('estadoCaja').value = c.estadoCaja?.idEstadoCaja || 1;
                        
                        // ABRIR MODAL (SOLO AQUÍ)
                        abrirModalCaja();
                    })
                    .catch(err => {
                        console.error('❌ Error:', err);
                        alert('Error al cargar la caja');
                    });
            }

            // ========================================================
            // GUARDAR CAJA
            // ========================================================
            function guardarCaja() {
                const id = document.getElementById('cajaId').value;
                const caja = {
                    nombreCaja: document.getElementById('nombreCaja').value.trim(),
                    numeroCaja: parseInt(document.getElementById('numeroCaja').value) || 0,
                    estadoCaja: {
                        idEstadoCaja: parseInt(document.getElementById('estadoCaja').value)
                    }
                };

                if (!caja.nombreCaja) {
                    alert('El nombre es obligatorio');
                    return;
                }

                fetch(`${API_CAJAS}/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(caja)
                })
                .then(res => {
                    if (!res.ok) throw new Error('Error al actualizar');
                    return res.json();
                })
                .then(() => {
                    // Cerrar modal
                    cerrarModalCaja();
                    // Recargar tabla
                    cargarCajas();
                    alert('✅ Caja actualizada exitosamente');
                })
                .catch(err => {
                    console.error('❌ Error:', err);
                    alert('Error al actualizar la caja');
                });
            }

            // ========================================================
            // EXPONER FUNCIONES
            // ========================================================
            window.cargarCajas = cargarCajas;
            window.editarCaja = editarCaja;
            window.guardarCaja = guardarCaja;
            window.cerrarModalCaja = cerrarModalCaja;

            // ========================================================
            // AUTO-EJECUTAR AL CARGAR
            // ========================================================
            document.addEventListener('DOMContentLoaded', cargarCajas);
            
            if (document.readyState === 'complete' || document.readyState === 'interactive') {
                cargarCajas();
            }
        })();
    </script>
</body>
</html>