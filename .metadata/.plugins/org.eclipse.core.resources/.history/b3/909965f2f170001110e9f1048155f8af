<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Gestión de Ofertas</title>
</head>
<body>
    <div class="container-fluid mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="fas fa-tags text-success"></i> Gestión de Ofertas</h2>
            <div>
                <button class="btn btn-outline-success" onclick="cargarOfertas()">
                    <i class="fas fa-sync"></i> Actualizar
                </button>
                <button class="btn btn-info" onclick="cargarOfertasVigentes()">
                    <i class="fas fa-clock"></i> Solo Vigentes
                </button>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover" id="tablaOfertas">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Producto</th>
                                <th>Descripción</th>
                                <th>Descuento</th>
                                <th>Fecha Inicio</th>
                                <th>Fecha Fin</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="cuerpoTablaOfertas">
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="fas fa-spinner fa-spin"></i> Cargando ofertas...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Aprobar Oferta -->
    <div class="modal fade" id="modalOferta" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title"><i class="fas fa-check-circle"></i> Aprobar Oferta</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="ofertaId">
                    <div id="ofertaDetalle"></div>
                    <div class="mb-3">
                        <label class="form-label">ID Usuario (Aprobador)</label>
                        <input type="number" class="form-control" id="idUsuarioAprobador" value="1" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-success" onclick="aprobarOferta()">
                        <i class="fas fa-check"></i> Aprobar Oferta
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const API_OFERTAS = '/supervisor/ofertas';
        let modalOferta = null;

        document.addEventListener('DOMContentLoaded', function() {
            modalOferta = new bootstrap.Modal(document.getElementById('modalOferta'));
            cargarOfertas();
        });

        function cargarOfertas() {
            fetch(API_OFERTAS)
                .then(res => res.json())
                .then(ofertas => {
                    renderizarOfertas(ofertas);
                })
                .catch(err => {
                    console.error('Error:', err);
                    document.getElementById('cuerpoTablaOfertas').innerHTML = 
                        `<tr><td colspan="8" class="text-center text-danger">Error al cargar las ofertas</td></tr>`;
                });
        }

        function cargarOfertasVigentes() {
            fetch(`${API_OFERTAS}/vigentes`)
                .then(res => res.json())
                .then(ofertas => {
                    renderizarOfertas(ofertas);
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Error al cargar ofertas vigentes');
                });
        }

        function renderizarOfertas(ofertas) {
            const tbody = document.getElementById('cuerpoTablaOfertas');
            if (!ofertas || ofertas.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="text-center text-muted">No hay ofertas registradas</td></tr>`;
                return;
            }
            let html = '';
            ofertas.forEach(o => {
                const badge = o.estado === 'APROBADO' ? 'success' : o.estado === 'RECHAZADO' ? 'danger' : 'warning';
                html += `
                    <tr>
                        <td>${o.idOferta}</td>
                        <td>${o.producto?.nombre || 'N/A'}</td>
                        <td>${o.descripcion || '-'}</td>
                        <td><span class="badge bg-primary">${o.descuento || 0}%</span></td>
                        <td>${o.fechaInicio ? new Date(o.fechaInicio).toLocaleDateString() : '-'}</td>
                        <td>${o.fechaFin ? new Date(o.fechaFin).toLocaleDateString() : '-'}</td>
                        <td><span class="badge bg-${badge}">${o.estado || 'PENDIENTE'}</span></td>
                        <td>
                            ${o.estado === 'PENDIENTE' ? `
                                <button class="btn btn-sm btn-success" onclick="abrirModalAprobar(${o.idOferta})">
                                    <i class="fas fa-check"></i> Aprobar
                                </button>
                            ` : `
                                <span class="text-muted">${o.estado === 'APROBADO' ? '✓ Aprobada' : '✗ Rechazada'}</span>
                            `}
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function abrirModalAprobar(id) {
            fetch(`${API_OFERTAS}/${id}`)
                .then(res => res.json())
                .then(o => {
                    document.getElementById('ofertaId').value = id;
                    document.getElementById('ofertaDetalle').innerHTML = `
                        <p><strong>Producto:</strong> ${o.producto?.nombre || 'N/A'}</p>
                        <p><strong>Descripción:</strong> ${o.descripcion || '-'}</p>
                        <p><strong>Descuento:</strong> ${o.descuento || 0}%</p>
                        <p><strong>Fecha Inicio:</strong> ${o.fechaInicio ? new Date(o.fechaInicio).toLocaleDateString() : '-'}</p>
                        <p><strong>Fecha Fin:</strong> ${o.fechaFin ? new Date(o.fechaFin).toLocaleDateString() : '-'}</p>
                        <hr>
                        <p class="text-success"><strong>¿Estás seguro de aprobar esta oferta?</strong></p>
                    `;
                    modalOferta.show();
                })
                .catch(err => {
                    console.error('Error:', err);
                    alert('Error al cargar la oferta');
                });
        }

        function aprobarOferta() {
            const id = document.getElementById('ofertaId').value;
            const idUsuario = document.getElementById('idUsuarioAprobador').value;

            if (!idUsuario) {
                alert('El ID de usuario es obligatorio');
                return;
            }

            fetch(`${API_OFERTAS}/${id}/aprobar?idUsuario=${idUsuario}`, {
                method: 'PUT'
            })
            .then(res => {
                if (!res.ok) throw new Error('Error al aprobar');
                return res.json();
            })
            .then(() => {
                modalOferta.hide();
                cargarOfertas();
                alert('Oferta aprobada exitosamente');
            })
            .catch(err => {
                console.error('Error:', err);
                alert('Error al aprobar la oferta');
            });
        }
    </script>
</body>
</html>